# ── Ollama settings ──────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Models (pulled via: ollama pull <name>) ───────────────────────────────────
PRIMARY_MODEL=qwen2.5:7b-instruct-q4_K_M
SECONDARY_MODEL=llama3.2:3b-instruct-q4_K_M
EMBEDDING_MODEL=nomic-embed-text

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMADB_PATH=./data/chromadb
CHROMADB_COLLECTION=fairsynth_compliance

# ── Storage paths ─────────────────────────────────────────────────────────────
JOBS_DIR=./data/jobs
BIAS_JOBS_DIR=./data/bias_jobs
KNOWLEDGE_BASE_DIR=./knowledge_base

# ── DuckDB ────────────────────────────────────────────────────────────────────
DUCKDB_PATH=./data/fairsynth.duckdb

# ── Pipeline settings ─────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=500
MAX_STATS_COLUMNS=100
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3
DEFAULT_EPSILON_BUDGET=10.0

# ── Quality thresholds ────────────────────────────────────────────────────────
MIN_KS_SCORE=0.85
MIN_QUALITY_SCORE=0.80
